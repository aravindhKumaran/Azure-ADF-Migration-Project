									"name": "airline_id",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "airline_name",
									"type": "String",
									"physicalType": "String"
								},
								"sink": {
									"name": "airline_name",
									"type": "String",
									"physicalType": "String"
								}
							},
							{
								"source": {
									"name": "country",
